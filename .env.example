# Zhongchi deployment environment template.
# Copy to .env on the server and fill real values there.
# Do not commit the real .env file.

# =============================================================================
# Frontend - server-side proxy config
# =============================================================================
# Next.js 服务端会将 /api/* 请求代理到此地址（rewrites）。
# 本机开发用 127.0.0.1:8010；Docker 中设为 http://backend:8010。
BACKEND_URL=http://127.0.0.1:8010

# =============================================================================
# Backend - LLM chat/completions test and future generation
# =============================================================================
# Use the exact callable URL required by your relay/provider.
# This project does not append /v1/chat/completions automatically.
ZHONGCHI_LLM_BASE_URL=https://example.com/v1/chat/completions
ZHONGCHI_LLM_API_KEY=replace-with-real-key
ZHONGCHI_LLM_MODEL=gpt-5.5

# =============================================================================
# Backend - file/data storage
# =============================================================================
# Persistent server directory for JSON db, uploads, outputs and parsed text.
ZHONGCHI_DATA_DIR=/srv/zhongchi/data

# Historical case source directories. Keep defaults if you deploy these paths
# inside the project, otherwise point them to persistent server directories.
ZHONGCHI_CASE_LIBRARY_DIR=/srv/zhongchi/case_library
ZHONGCHI_SR_PPT_SPLIT_DIR=/srv/zhongchi/sr_ppt_split

# =============================================================================
# Backend/PPT engine - templates and merge behavior
# =============================================================================
ZHONGCHI_PPT_TEMPLATE_ROOT=/srv/zhongchi/templates/solution_fixed_modules
# Allowed values: auto, powerpoint, python-pptx
ZHONGCHI_PPT_MERGE_ENGINE=powerpoint
# Enable LLM-based M1/M2 classification (1/on by default; 0/off to use rules only).
ZHONGCHI_M1M2_LLM_ENABLED=1
# Max upload size in bytes (default 200MB = 209715200).
ZHONGCHI_MAX_UPLOAD_BYTES=209715200

# =============================================================================
# Vector store - optional pgvector integration
# =============================================================================
# Leave ZHONGCHI_VECTOR_DSN empty to disable vector indexing.
ZHONGCHI_VECTOR_DSN=
ZHONGCHI_VECTOR_TABLE=zhongchi_embeddings

# Embedding defaults. Keep hash for offline/dev fallback. Use openrouter only
# when OPENROUTER_API_KEY is configured and the model/base URL are valid.
ZHONGCHI_EMBEDDING_PROVIDER=hash
ZHONGCHI_EMBEDDING_DIM=1536
ZHONGCHI_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
ZHONGCHI_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
OPENROUTER_API_KEY=
